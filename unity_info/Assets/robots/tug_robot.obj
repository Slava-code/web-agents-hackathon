v -0.27 0.06 -0.28
v -0.22 0.00 -0.28
v -0.22 0.06 -0.28
v -0.27 0.00 -0.22
v -0.27 0.06 -0.22
v -0.22 0.00 -0.22
v -0.22 0.06 -0.22

f 25 26 28 27
f 29 30 32 31
f 25 29 30 26
