v 0.27 0.06 -0.22

f 33 34 36 35
f 37 38 40 39
f 33 37 38 34
f 35 39 40 36
f 33 35 39 37
f 34 36 40 38

# ========================================
# PART 3: LOWER BODY (main compartment)
# ========================================
o Lower_Body

# y=0.10 to y=0.55
v -0.23 0.10 -0.33
v  0.23 0.10 -0.33
v  0.23 0.10  0.33
v -0.23 0.10  0.33
v -0.23 0.55 -0.33
